{
    "name": "svelte-template",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "generate-types": "openapi-typescript http://localhost:8000/schema/openapi.json --output src/lib/types/api.ts",
        "dev": "vite dev --host 0.0.0.0 --port 8000",
        "build": "svelte-kit sync && vite build",
        "lint": "biome check . --error-on-warnings",
        "lint:fix": "biome check . --write --error-on-warnings",
        "format": "biome format .",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "precommit": "npm run build && npm run lint && npm run check",
        "prepush": "npm run precommit && npm run test:unit && npm run test:integration",
        "test": "npm run test:unit -- --run && npm run test:e2e",
        "test:unit": "vitest run",
        "test:e2e": "playwright test"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.4",
        "@ffmpeg/ffmpeg": "^0.12.15",
        "@ffmpeg/util": "^0.12.2",
        "@sveltejs/adapter-static": "^3.0.8",
        "@sveltejs/kit": "^2.22.0",
        "@sveltejs/vite-plugin-svelte": "^6.0.0",
        "@tailwindcss/vite": "^4.0.0",
        "@vitest/browser": "^4.1.1",
        "@vitest/browser-playwright": "^4.1.1",
        "globals": "^16.0.0",
        "jszip": "^3.10.1",
        "openapi-typescript": "^7.9.1",
        "svelte": "^5.0.0",
        "svelte-check": "^4.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.0.0",
        "vite": "^7.0.0",
        "vitest": "^4.1.1",
        "vitest-browser-svelte": "^2.1.0",
        "zod": "^4.3.6"
    }
}
